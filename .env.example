# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
# For local development: mongodb://localhost:27017/vehicle-marketplace
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/vehicle-marketplace?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/vehicle-marketplace?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=1h
